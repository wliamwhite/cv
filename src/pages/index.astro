---
import Layout from '../layouts/Layout.astro';

const experience = [
	{
		company: 'Wipfli LLP',
		location: 'Minneapolis, MN',
		role: 'Software Developer',
		period: 'Jan 2026 — Present',
		bullets: [
			'Develop, test, and ship AI orchestration and agentic applications.',
			'Full-time member of the ERP and CRM consulting practice; deliver implementations across Business Central, Sage Intacct, Salesforce, Concur, and SAP.',
			'Sole developer of an end-to-end Microsoft AppSource punchout eProcurement application for Business Central — designed, built, and shipped independently over six months.',
			'Personally manage cross-functional engagements and go-to-market strategy.',
		],
	},
	{
		company: 'Wipfli LLP',
		location: 'Minneapolis, MN',
		role: 'Software Developer Intern',
		period: 'Jun 2024 — Dec 2025',
		bullets: [
			'Full-time summers 2024 and 2025; part-time during spring and fall academic semesters.',
			'Contributed to enterprise ERP and accounting software across multiple client engagements in a C# .NET environment.',
			'Rotated through business units, developing cross-functional exposure to ERP, CRM, and financial systems consulting.',
			'Networked with firm partners and managed client-facing communications independently.',
		],
	},
	{
		company: 'M&E Catalyst Group',
		location: 'Minneapolis, MN',
		role: 'Financial Paraplanner · MassMutual Affiliate',
		period: 'Feb 2021 — Feb 2022',
		bullets: [
			'Prepared end-to-end financial plans and compliance documentation for 40+ named clients.',
			'Authored a custom software tool to automate data migration and overhaul internal data-storage architecture.',
			'Passed the SIE, Series 7, and Series 66 examinations during tenure.',
			'Managed direct client relationships; conducted needs assessments and delivered tailored financial roadmaps.',
		],
	},
	{
		company: 'Feller Restaurant',
		location: 'Stillwater, MN',
		role: 'Server',
		period: 'Feb 2022 — Aug 2022',
		bullets: [
			'Front-of-house service at an upscale fine-dining establishment; managed full-cycle guest experience.',
			'Used the period to earn AWS Certified Cloud Developer certification and build up software portfolio.',
		],
	},
];

const education = [
	{
		school: 'University of Wisconsin–Eau Claire',
		location: 'Eau Claire, WI',
		credential: 'B.S., Computer Science',
		period: 'Sep 2022 — Dec 2025',
		notes: [
			'Major GPA: 3.2',
			'Student Researcher — designed and developed an AI curling simulator; managed from inception to production.',
			"Professor's Assistant — held office hours and supported peers through coursework and laboratory projects.",
			'President, Chess Club.',
		],
	},
	{
		school: 'St. Croix Preparatory Academy',
		location: 'Stillwater, MN',
		credential: 'Classical K–12 Education',
		period: 'Graduated 2020',
		notes: ['ACT: 35'],
	},
];

const skills = [
	{ group: 'Languages', items: 'C#, C++, Python, Java, JavaScript / Node.js, Haskell, AL (Business Central)' },
	{ group: 'ERP / CRM', items: 'Business Central, Sage Intacct, Salesforce, SAP, Concur' },
	{ group: 'Databases', items: 'MySQL, MongoDB, DynamoDB' },
	{ group: 'Cloud', items: 'AWS (certified), Azure (AppSource deployment)' },
];

const certifications = [
	'CFA Candidate — Level I passed (February 2026)',
	'AWS Certified Cloud Developer — Reg. No. 2169084',
	'SIE / Series 7 / Series 66 — passed; lapsed',
	'Russian Language — B2 / C1 proficiency',
];

const activities = [
	{ title: 'UW Master Naturalist Program', detail: 'Currently enrolled; 8-session all-day volunteer and education curriculum.' },
	{ title: 'Independent Trading & Investing', detail: 'Active since 2021 — equities, options, commodities.' },
	{ title: 'Big Brothers Big Sisters', detail: 'Volunteer Big.' },
	{ title: 'Chess', detail: 'Club president; competitive player.' },
];

const interests = 'Quantum computing & financial markets · Writing & independent research · Russian language & literature · Camping, hiking & wilderness · Chess · History & classical philosophy · Sustainable agriculture';
---

<Layout>
	<div class="page" id="top">
		<header class="masthead">
			<h1 class="name">Liam White</h1>
			<p class="subtitle">Software Developer · Lake Elmo, Minnesota</p>
			<nav class="toc">
				<a href="#about">About</a>
				<span>·</span>
				<a href="#experience">Experience</a>
				<span>·</span>
				<a href="#education">Education</a>
				<span>·</span>
				<a href="#skills">Skills</a>
				<span>·</span>
				<a href="#activities">Activities</a>
				<span>·</span>
				<a href="#contact">Contact</a>
				<span>·</span>
				<a href="/LiamWhite-Resume.pdf" download>Résumé (PDF)</a>
			</nav>
		</header>

		<section id="about" class="section">
			<h2>About.</h2>
			<p>
				I am a software developer at <a href="https://www.wipfli.com" target="_blank" rel="noreferrer">Wipfli LLP</a>,
				working inside the firm's ERP and CRM consulting practice. My day-to-day is split between shipping
				AI orchestration and agentic applications and delivering implementations across Business Central,
				Sage Intacct, Salesforce, Concur, and SAP.
			</p>
			<p>
				Before software I spent a year as a financial paraplanner under a MassMutual affiliate, preparing
				end-to-end plans for 40+ clients and passing the SIE, Series 7, and Series 66. That thread is still
				active: I passed the CFA Level I in February 2026 and trade my own book in equities, options, and
				commodities.
			</p>
			<p>
				Outside work I read Russian literature, play competitive chess, and spend as many weekends as I can
				in the wilderness — currently working through the UW Master Naturalist curriculum.
			</p>
		</section>

		<section id="experience" class="section">
			<h2>Experience.</h2>
			{experience.map((job) => (
				<article class="entry">
					<header class="entry-head">
						<div class="entry-title">
							<strong>{job.company}</strong>, {job.location}.
							<em>{job.role}.</em>
						</div>
						<div class="entry-period mono">{job.period}</div>
					</header>
					<ul>
						{job.bullets.map((b) => <li>{b}</li>)}
					</ul>
				</article>
			))}
		</section>

		<section id="education" class="section">
			<h2>Education.</h2>
			{education.map((ed) => (
				<article class="entry">
					<header class="entry-head">
						<div class="entry-title">
							<strong>{ed.school}</strong>, {ed.location}.
							<em>{ed.credential}.</em>
						</div>
						<div class="entry-period mono">{ed.period}</div>
					</header>
					<ul>
						{ed.notes.map((n) => <li>{n}</li>)}
					</ul>
				</article>
			))}
		</section>

		<section id="skills" class="section">
			<h2>Skills &amp; Certifications.</h2>
			<dl class="deflist">
				{skills.map((s) => (
					<>
						<dt>{s.group}</dt>
						<dd>{s.items}</dd>
					</>
				))}
				<dt>Certifications</dt>
				<dd>
					<ul class="inline">
						{certifications.map((c) => <li>{c}</li>)}
					</ul>
				</dd>
			</dl>
		</section>

		<section id="activities" class="section">
			<h2>Activities &amp; Interests.</h2>
			<dl class="deflist">
				{activities.map((a) => (
					<>
						<dt>{a.title}</dt>
						<dd>{a.detail}</dd>
					</>
				))}
			</dl>
			<p class="interests">{interests}</p>
		</section>

		<section id="contact" class="section">
			<h2>Contact.</h2>
			<dl class="deflist">
				<dt>Email</dt>
				<dd><a href="mailto:wLiamWhite@gmail.com">wLiamWhite@gmail.com</a></dd>
				<dt>Telephone</dt>
				<dd><a href="tel:+16512337192">651.233.7192</a></dd>
				<dt>Résumé</dt>
				<dd><a href="/LiamWhite-Resume.pdf" download>LiamWhite-Resume.pdf</a></dd>
				<dt>CRD</dt>
				<dd>7335702</dd>
			</dl>
		</section>

		<footer class="colophon">
			<hr />
			<p>
				<span>Liam White · Lake Elmo, Minnesota · {new Date().getFullYear()}</span>
				<span><a href="#top">↑ top</a></span>
			</p>
		</footer>
	</div>
</Layout>

<style>
	.page {
		max-width: 720px;
		margin: 0 auto;
		padding: 56px 28px 80px;
	}

	/* Masthead */
	.masthead {
		border-bottom: 2px solid var(--rule);
		padding-bottom: 20px;
		margin-bottom: 48px;
	}

	.name {
		font-size: 36px;
		font-weight: 700;
		letter-spacing: 0;
		line-height: 1.15;
		margin: 0 0 4px;
	}

	.subtitle {
		font-style: italic;
		color: var(--ink-soft);
		margin: 0 0 16px;
		font-size: 16px;
	}

	.toc {
		font-size: 15px;
		color: var(--ink-muted);
		line-height: 1.9;
	}

	.toc a {
		color: var(--link);
	}

	.toc span {
		margin: 0 6px;
		color: var(--rule-soft);
	}

	/* Sections */
	.section {
		margin-bottom: 44px;
	}

	.section h2 {
		font-size: 22px;
		font-weight: 700;
		border-bottom: 1px solid var(--rule);
		padding-bottom: 4px;
		margin: 0 0 20px;
	}

	.section p {
		margin: 0 0 14px;
	}

	.section p:last-child {
		margin-bottom: 0;
	}

	/* Entries (experience + education) */
	.entry {
		margin-bottom: 28px;
	}

	.entry:last-child {
		margin-bottom: 0;
	}

	.entry-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 16px;
		margin-bottom: 6px;
	}

	.entry-title {
		line-height: 1.4;
	}

	.entry-title strong {
		font-weight: 700;
	}

	.entry-title em {
		font-style: italic;
		color: var(--ink-soft);
	}

	.entry-period {
		font-size: 13px;
		color: var(--ink-muted);
		white-space: nowrap;
		flex-shrink: 0;
	}

	.entry ul {
		list-style: disc;
		padding-left: 22px;
		margin: 6px 0 0;
	}

	.entry li {
		margin-bottom: 4px;
		line-height: 1.5;
	}

	.entry li:last-child {
		margin-bottom: 0;
	}

	/* Definition lists */
	.deflist {
		display: grid;
		grid-template-columns: 180px 1fr;
		gap: 8px 20px;
		margin: 0 0 16px;
	}

	.deflist dt {
		font-weight: 700;
	}

	.deflist dd {
		margin: 0;
		color: var(--ink-soft);
	}

	.deflist ul.inline {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.deflist ul.inline li {
		margin-bottom: 2px;
	}

	.interests {
		margin-top: 20px;
		padding-top: 14px;
		border-top: 1px dashed var(--rule-soft);
		font-style: italic;
		color: var(--ink-soft);
		font-size: 15px;
	}

	/* Colophon */
	.colophon {
		margin-top: 72px;
	}

	.colophon hr {
		border: none;
		border-top: 2px solid var(--rule);
		margin: 0 0 10px;
	}

	.colophon p {
		display: flex;
		justify-content: space-between;
		font-size: 13px;
		color: var(--ink-muted);
		margin: 0;
	}

	/* Responsive */
	@media (max-width: 640px) {
		.page {
			padding: 36px 20px 60px;
		}

		.name {
			font-size: 30px;
		}

		.entry-head {
			flex-direction: column;
			gap: 2px;
		}

		.entry-period {
			font-size: 12px;
		}

		.deflist {
			grid-template-columns: 1fr;
			gap: 2px 0;
		}

		.deflist dt {
			margin-top: 10px;
		}

		.deflist dt:first-child {
			margin-top: 0;
		}
	}
</style>
