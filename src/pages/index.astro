---
import Layout from '../layouts/Layout.astro';

const experience = [
	{
		company: 'Wipfli LLP',
		location: 'Minneapolis, MN',
		role: 'Software Developer',
		period: 'January 2026 — Present',
		bullets: [
			'Develop, test, and ship AI orchestration and agentic applications.',
			'Full-time member of the ERP and CRM consulting practice; deliver implementations across Business Central, Sage Intacct, Salesforce, Concur, and SAP.',
			'Sole developer of an end-to-end Microsoft AppSource punchout eProcurement application for Business Central — designed, built, and shipped independently over six months.',
			'Personally manage cross-functional engagements and go-to-market strategy.',
		],
	},
	{
		company: 'Wipfli LLP',
		location: 'Minneapolis, MN',
		role: 'Software Developer Intern',
		period: 'June 2024 — December 2025',
		bullets: [
			'Full-time summers 2024 and 2025; part-time during spring and fall academic semesters.',
			'Contributed to enterprise ERP and accounting software across multiple client engagements in a C# .NET environment.',
			'Rotated through business units, developing cross-functional exposure to ERP, CRM, and financial systems consulting.',
			'Networked with firm partners and managed client-facing communications independently.',
		],
	},
	{
		company: 'M&E Catalyst Group',
		location: 'Minneapolis, MN',
		role: 'Financial Paraplanner · MassMutual Affiliate',
		period: 'February 2021 — February 2022',
		bullets: [
			'Prepared end-to-end financial plans and compliance documentation for 40+ named clients.',
			'Authored a custom software tool to automate data migration and overhaul internal data-storage architecture.',
			'Passed the SIE, Series 7, and Series 66 examinations during tenure.',
			'Managed direct client relationships; conducted needs assessments and delivered tailored financial roadmaps.',
		],
	},
	{
		company: 'Feller Restaurant',
		location: 'Stillwater, MN',
		role: 'Server',
		period: 'February 2022 — August 2022',
		bullets: [
			'Front-of-house service at an upscale fine-dining establishment; managed full-cycle guest experience.',
			'Used the period to earn AWS Certified Cloud Developer certification and build up software portfolio.',
		],
	},
];

const education = [
	{
		school: 'University of Wisconsin–Eau Claire',
		location: 'Eau Claire, WI',
		credential: 'B.S., Computer Science',
		period: 'September 2022 — December 2025',
		notes: [
			'Major GPA: 3.2',
			'Student Researcher — designed and developed an AI curling simulator; managed from inception to production.',
			"Professor's Assistant — held office hours and supported peers through coursework and laboratory projects.",
			'President, Chess Club.',
		],
	},
	{
		school: 'St. Croix Preparatory Academy',
		location: 'Stillwater, MN',
		credential: 'Classical K–12 Education',
		period: 'Graduated 2020',
		notes: ['ACT: 35'],
	},
];

const skills = [
	{ group: 'Languages', items: ['C#', 'C++', 'Python', 'Java', 'JavaScript / Node.js', 'Haskell', 'AL (Business Central)'] },
	{ group: 'ERP / CRM', items: ['Business Central', 'Sage Intacct', 'Salesforce', 'SAP', 'Concur'] },
	{ group: 'Databases', items: ['MySQL', 'MongoDB', 'DynamoDB'] },
	{ group: 'Cloud', items: ['AWS (certified)', 'Azure (AppSource deployment)'] },
];

const certifications = [
	'CFA Candidate — Level I passed (February 2026)',
	'AWS Certified Cloud Developer — Reg. No. 2169084',
	'SIE / Series 7 / Series 66 — passed; lapsed',
	'Russian Language — B2 / C1 proficiency',
];

const activities = [
	{ title: 'UW Master Naturalist Program', detail: 'Currently enrolled; 8-session all-day volunteer and education curriculum.' },
	{ title: 'Independent Trading & Investing', detail: 'Active since 2021 — equities, options, commodities.' },
	{ title: 'Big Brothers Big Sisters', detail: 'Volunteer Big.' },
	{ title: 'Chess', detail: 'Club president; competitive player.' },
];

const interests = [
	'Quantum computing & financial markets',
	'Writing & independent research',
	'Russian language & literature',
	'Camping, hiking & wilderness',
	'Chess',
	'History & classical philosophy',
	'Sustainable agriculture',
];
---

<Layout>
	<div class="page">
		<header class="nav">
			<div class="nav-inner">
				<a class="brand" href="#top">LW</a>
				<nav>
					<a href="#about">About</a>
					<a href="#experience">Experience</a>
					<a href="#education">Education</a>
					<a href="#skills">Skills</a>
					<a href="#contact">Contact</a>
				</nav>
			</div>
		</header>

		<main id="top">
			<section class="hero">
				<p class="eyebrow">Software Developer · Lake Elmo, MN</p>
				<h1>Liam White.</h1>
				<p class="lede">
					Software developer at <a href="https://www.wipfli.com" target="_blank" rel="noreferrer">Wipfli LLP</a>,
					shipping AI orchestration and agentic applications inside the firm's ERP and CRM consulting practice.
					Background in finance, an appetite for systems thinking, and a classical grounding.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="/LiamWhite-Resume.pdf" download>Download résumé</a>
					<a class="btn btn-ghost" href="mailto:wLiamWhite@gmail.com">Get in touch →</a>
				</div>
				<dl class="facts">
					<div><dt>Based</dt><dd>Lake Elmo, MN</dd></div>
					<div><dt>Focus</dt><dd>AI orchestration · ERP/CRM · full-stack</dd></div>
					<div><dt>Credentials</dt><dd>AWS CCD · CFA L1 · CRD 7335702</dd></div>
				</dl>
			</section>

			<section id="about" class="section">
				<div class="section-head">
					<span class="section-number">01</span>
					<h2>About</h2>
				</div>
				<div class="section-body prose">
					<p>
						I'm a software developer with a full-time seat in Wipfli's ERP and CRM consulting practice, where
						I build AI orchestration and agentic applications and deliver implementations across
						Business Central, Sage Intacct, Salesforce, Concur, and SAP.
					</p>
					<p>
						Before software, I worked as a financial paraplanner under a MassMutual affiliate, preparing
						end-to-end plans for 40+ clients and passing the SIE, Series 7, and Series 66. That finance
						thread is still active — I'm a CFA Level I candidate (passed Feb 2026) and trade my own book
						in equities, options, and commodities.
					</p>
					<p>
						Outside work I read Russian literature, play competitive chess, and spend as many weekends
						as I can in the wilderness — currently working through the UW Master Naturalist curriculum.
					</p>
				</div>
			</section>

			<section id="experience" class="section">
				<div class="section-head">
					<span class="section-number">02</span>
					<h2>Experience</h2>
				</div>
				<div class="section-body">
					<ol class="timeline">
						{experience.map((job) => (
							<li class="timeline-item">
								<div class="timeline-meta">
									<span class="timeline-period">{job.period}</span>
									<span class="timeline-location">{job.location}</span>
								</div>
								<div class="timeline-body">
									<h3>
										{job.role} <span class="at">·</span> <span class="company">{job.company}</span>
									</h3>
									<ul class="bullets">
										{job.bullets.map((b) => <li>{b}</li>)}
									</ul>
								</div>
							</li>
						))}
					</ol>
				</div>
			</section>

			<section id="education" class="section">
				<div class="section-head">
					<span class="section-number">03</span>
					<h2>Education</h2>
				</div>
				<div class="section-body">
					<div class="edu-grid">
						{education.map((ed) => (
							<article class="edu-card">
								<h3>{ed.school}</h3>
								<p class="edu-cred">{ed.credential}</p>
								<p class="edu-meta">{ed.location} · {ed.period}</p>
								<ul class="bullets">
									{ed.notes.map((n) => <li>{n}</li>)}
								</ul>
							</article>
						))}
					</div>
				</div>
			</section>

			<section id="skills" class="section">
				<div class="section-head">
					<span class="section-number">04</span>
					<h2>Skills &amp; Certifications</h2>
				</div>
				<div class="section-body">
					<div class="skills-grid">
						{skills.map((s) => (
							<div class="skill-block">
								<h4>{s.group}</h4>
								<ul class="tags">
									{s.items.map((i) => <li>{i}</li>)}
								</ul>
							</div>
						))}
					</div>
					<div class="cert-block">
						<h4>Certifications</h4>
						<ul class="bullets">
							{certifications.map((c) => <li>{c}</li>)}
						</ul>
					</div>
				</div>
			</section>

			<section id="activities" class="section">
				<div class="section-head">
					<span class="section-number">05</span>
					<h2>Activities &amp; Interests</h2>
				</div>
				<div class="section-body">
					<div class="activities">
						{activities.map((a) => (
							<div class="activity">
								<h4>{a.title}</h4>
								<p>{a.detail}</p>
							</div>
						))}
					</div>
					<p class="interests">
						{interests.join(' · ')}
					</p>
				</div>
			</section>

			<section id="contact" class="section contact">
				<div class="section-head">
					<span class="section-number">06</span>
					<h2>Contact</h2>
				</div>
				<div class="section-body">
					<p class="contact-lede">
						Open to conversations on AI orchestration, ERP/CRM systems, quantitative work, and anything
						at the intersection of software and capital markets.
					</p>
					<ul class="contact-list">
						<li>
							<span class="label">Email</span>
							<a href="mailto:wLiamWhite@gmail.com">wLiamWhite@gmail.com</a>
						</li>
						<li>
							<span class="label">Phone</span>
							<a href="tel:+16512337192">651.233.7192</a>
						</li>
						<li>
							<span class="label">Résumé</span>
							<a href="/LiamWhite-Resume.pdf" download>LiamWhite-Resume.pdf</a>
						</li>
						<li>
							<span class="label">CRD</span>
							<span>7335702</span>
						</li>
					</ul>
				</div>
			</section>
		</main>

		<footer class="footer">
			<span>© {new Date().getFullYear()} Liam White</span>
			<span>Lake Elmo, Minnesota</span>
		</footer>
	</div>
</Layout>

<style>
	.page {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 32px;
	}

	/* Navigation */
	.nav {
		position: sticky;
		top: 0;
		z-index: 10;
		background: rgba(247, 245, 240, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--rule);
		margin: 0 -32px;
		padding: 0 32px;
	}

	.nav-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 64px;
	}

	.brand {
		font-family: Fraunces, serif;
		font-size: 20px;
		font-weight: 600;
		color: var(--ink);
		letter-spacing: 0.08em;
	}

	.nav nav {
		display: flex;
		gap: 28px;
	}

	.nav nav a {
		color: var(--ink-soft);
		font-size: 14px;
		font-weight: 500;
	}

	.nav nav a:hover {
		color: var(--ink);
	}

	/* Hero */
	.hero {
		padding: 120px 0 80px;
		max-width: 760px;
	}

	.eyebrow {
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0 0 20px;
	}

	.hero h1 {
		font-size: clamp(56px, 9vw, 108px);
		line-height: 0.95;
		margin: 0 0 28px;
		letter-spacing: -0.03em;
		font-weight: 500;
	}

	.lede {
		font-size: 20px;
		line-height: 1.55;
		color: var(--ink-soft);
		margin: 0 0 36px;
		max-width: 640px;
	}

	.hero-actions {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
		margin-bottom: 56px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		padding: 12px 22px;
		border-radius: 999px;
		font-size: 15px;
		font-weight: 500;
		border: 1px solid transparent;
		transition: all 0.18s ease;
	}

	.btn-primary {
		background: var(--ink);
		color: var(--bg);
	}

	.btn-primary:hover {
		background: var(--accent);
		color: var(--bg);
	}

	.btn-ghost {
		color: var(--ink);
		border-color: var(--rule);
		background: transparent;
	}

	.btn-ghost:hover {
		border-color: var(--ink);
		color: var(--ink);
	}

	.facts {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 28px;
		margin: 0;
		padding: 24px 0 0;
		border-top: 1px solid var(--rule);
	}

	.facts > div {
		margin: 0;
	}

	.facts dt {
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink-muted);
		margin-bottom: 6px;
	}

	.facts dd {
		margin: 0;
		font-size: 15px;
		color: var(--ink);
	}

	/* Sections */
	.section {
		padding: 80px 0;
		border-top: 1px solid var(--rule);
		display: grid;
		grid-template-columns: 220px 1fr;
		gap: 48px;
	}

	.section-head {
		display: flex;
		align-items: baseline;
		gap: 14px;
		position: sticky;
		top: 96px;
		align-self: start;
	}

	.section-number {
		font-family: 'JetBrains Mono', monospace;
		font-size: 12px;
		color: var(--ink-muted);
		letter-spacing: 0.08em;
	}

	.section-head h2 {
		font-size: 28px;
		margin: 0;
	}

	.section-body {
		min-width: 0;
	}

	.prose p {
		font-size: 17px;
		line-height: 1.7;
		color: var(--ink-soft);
		margin: 0 0 18px;
	}

	.prose p:last-child {
		margin-bottom: 0;
	}

	/* Timeline */
	.timeline {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.timeline-item {
		display: grid;
		grid-template-columns: 180px 1fr;
		gap: 32px;
		padding: 28px 0;
		border-bottom: 1px solid var(--rule);
	}

	.timeline-item:first-child {
		padding-top: 0;
	}

	.timeline-item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.timeline-meta {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.timeline-period {
		font-family: 'JetBrains Mono', monospace;
		font-size: 12px;
		color: var(--ink);
		letter-spacing: 0.04em;
	}

	.timeline-location {
		font-size: 13px;
		color: var(--ink-muted);
	}

	.timeline-body h3 {
		font-size: 20px;
		margin: 0 0 12px;
		font-weight: 500;
		line-height: 1.3;
	}

	.timeline-body .at {
		color: var(--ink-muted);
		margin: 0 4px;
	}

	.timeline-body .company {
		color: var(--accent);
	}

	.bullets {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.bullets li {
		position: relative;
		padding-left: 18px;
		margin-bottom: 8px;
		color: var(--ink-soft);
		font-size: 15px;
		line-height: 1.6;
	}

	.bullets li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 10px;
		width: 6px;
		height: 1px;
		background: var(--ink-muted);
	}

	.bullets li:last-child {
		margin-bottom: 0;
	}

	/* Education */
	.edu-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 20px;
	}

	.edu-card {
		background: var(--bg-elevated);
		border: 1px solid var(--rule);
		border-radius: 12px;
		padding: 24px;
	}

	.edu-card h3 {
		font-size: 18px;
		margin: 0 0 4px;
		line-height: 1.3;
	}

	.edu-cred {
		font-size: 15px;
		color: var(--accent);
		margin: 0 0 4px;
	}

	.edu-meta {
		font-family: 'JetBrains Mono', monospace;
		font-size: 12px;
		color: var(--ink-muted);
		margin: 0 0 16px;
	}

	/* Skills */
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 28px 48px;
		margin-bottom: 40px;
	}

	.skill-block h4,
	.cert-block h4,
	.activity h4 {
		font-family: Inter, sans-serif;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--ink-muted);
		margin: 0 0 14px;
	}

	.tags {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.tags li {
		font-size: 13px;
		padding: 6px 12px;
		border: 1px solid var(--rule);
		border-radius: 999px;
		background: var(--bg-elevated);
		color: var(--ink);
	}

	.cert-block {
		padding-top: 28px;
		border-top: 1px solid var(--rule);
	}

	/* Activities */
	.activities {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 20px 40px;
		margin-bottom: 36px;
	}

	.activity h4 {
		margin-bottom: 6px;
	}

	.activity p {
		margin: 0;
		color: var(--ink-soft);
		font-size: 15px;
		line-height: 1.55;
	}

	.interests {
		font-family: Fraunces, serif;
		font-style: italic;
		font-size: 17px;
		color: var(--ink-soft);
		line-height: 1.6;
		padding-top: 28px;
		border-top: 1px solid var(--rule);
		margin: 0;
	}

	/* Contact */
	.contact-lede {
		font-size: 18px;
		color: var(--ink-soft);
		margin: 0 0 28px;
		max-width: 620px;
	}

	.contact-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.contact-list li {
		display: grid;
		grid-template-columns: 120px 1fr;
		padding: 16px 0;
		border-top: 1px solid var(--rule);
		align-items: baseline;
	}

	.contact-list li:last-child {
		border-bottom: 1px solid var(--rule);
	}

	.contact-list .label {
		font-family: 'JetBrains Mono', monospace;
		font-size: 12px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-muted);
	}

	.contact-list a,
	.contact-list span:not(.label) {
		font-size: 17px;
		color: var(--ink);
	}

	.contact-list a:hover {
		color: var(--accent);
	}

	/* Footer */
	.footer {
		display: flex;
		justify-content: space-between;
		padding: 32px 0 48px;
		border-top: 1px solid var(--rule);
		font-size: 13px;
		color: var(--ink-muted);
		font-family: 'JetBrains Mono', monospace;
		letter-spacing: 0.04em;
	}

	/* Responsive */
	@media (max-width: 820px) {
		.page {
			padding: 0 24px;
		}

		.nav {
			margin: 0 -24px;
			padding: 0 24px;
		}

		.nav nav {
			gap: 18px;
		}

		.nav nav a {
			font-size: 13px;
		}

		.hero {
			padding: 80px 0 56px;
		}

		.facts {
			grid-template-columns: 1fr;
			gap: 18px;
		}

		.section {
			grid-template-columns: 1fr;
			gap: 24px;
			padding: 56px 0;
		}

		.section-head {
			position: static;
		}

		.timeline-item {
			grid-template-columns: 1fr;
			gap: 12px;
		}

		.edu-grid,
		.skills-grid,
		.activities {
			grid-template-columns: 1fr;
		}

		.contact-list li {
			grid-template-columns: 1fr;
			gap: 4px;
		}
	}

	@media (max-width: 520px) {
		.nav-inner {
			height: 56px;
		}

		.nav nav {
			gap: 14px;
		}

		.brand {
			font-size: 18px;
		}
	}
</style>
